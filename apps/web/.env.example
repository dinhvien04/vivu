# Production Vercel:
# NEXT_PUBLIC_API_URL=https://vivu-api.vercel.app
# API_INTERNAL_URL=https://vivu-api.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated hostnames allowed by next/image.
# Production example: res.cloudinary.com,gia-lai-tourism-images.s3.ap-southeast-1.amazonaws.com,s3.ap-southeast-1.amazonaws.com
NEXT_IMAGE_REMOTE_HOSTS=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_ENABLED=true
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
CSP_CONNECT_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
