PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://vivu:vivu@localhost:5432/vivu?schema=public"
CORS_ORIGINS=http://localhost:3000

# Auth - generate strong random secrets for production, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=unused-refresh-tokens-are-stored-in-db
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Leave Meilisearch empty to use the PostgreSQL fallback for /search/suggest.
# When enabled, the service bootstraps the `places` index and syncs admin changes.
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=vivu_dev_master_key_change_me
MEILI_INDEX_PLACES=places

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TEXT_COLLECTION=text_collection_cloud
QDRANT_IMAGE_COLLECTION=image_collection_cloud

# Qdrant Cloud Inference models
QDRANT_TEXT_MODEL=intfloat/multilingual-e5-small
QDRANT_IMAGE_MODEL=qdrant/clip-vit-b-32-vision
QDRANT_IMAGE_TEXT_MODEL=qdrant/clip-vit-b-32-text

# AI retrieval
TOP_K_TEXT=5
TOP_K_IMAGES=5
IMAGE_MATCH_THRESHOLD=0.25
AI_MAX_IMAGE_SIZE_BYTES=4194304

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=gia-lai-tourism-images
S3_PRESIGNED_EXPIRES_IN=3600
S3_PRESIGNED_CACHE_MAX_ENTRIES=2000
REFERENCE_DATA_CACHE_TTL_MS=300000
