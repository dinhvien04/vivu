PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://vivu:vivu@localhost:5432/vivu?schema=public"
CORS_ORIGINS=http://localhost:3000

# Auth — generate strong random secrets for prod, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=unused-refresh-tokens-are-stored-in-db
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# MeiliSearch — bỏ trống để fallback về pg_trgm cho /search/suggest.
# Khi bật, service tự bootstrap index `places` và đồng bộ qua admin-places.
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=vivu_dev_master_key_change_me
MEILI_INDEX_PLACES=places
