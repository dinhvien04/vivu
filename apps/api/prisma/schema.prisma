// Prisma schema for Vivu API
// Note: PostGIS-specific types (geometry/geography) are not first-class in Prisma.
// Place table also has a `geo geography(Point, 4326)` column + GIST index +
// `place_geo_sync` trigger, declared in apps/api/prisma/schema.sql.
// It is kept in sync from (lat, lng) by the trigger and queried via $queryRaw
// (PlacesService.listNearby) — Prisma client is intentionally unaware of it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  editor
  admin
}

enum PlaceStatus {
  draft
  published
  archived
}

enum ReviewStatus {
  visible
  hidden
  reported
}

enum AiUsageKeyType {
  user
  ip_session
  ip
}

enum LeadSource {
  place_detail
  ai_chat
  trip_planner
  home
  other
}

enum LeadStatus {
  new
  contacted
  planning
  booked
  cancelled
  spam
}

enum DataReportType {
  wrong_image
  wrong_coordinates
  wrong_description
  missing_info
  other
}

enum DataReportStatus {
  new
  reviewed
  resolved
  rejected
}

enum AnalyticsEventType {
  place_view
  ai_chat_started
  home_trip_planner_cta_clicked
  home_consulting_cta_clicked
  trip_planner_preset_clicked
  trip_plan_generate_clicked
  trip_plan_generated
  trip_plan_failed
  trip_plan_feedback_submitted
  trip_plan_missing_data
  trip_plan_shared
  trip_plan_copied
  ai_feedback_submitted
  ai_missing_context
  lead_submitted
  lead_form_submitted
  detail_consulting_clicked
  detail_report_clicked
  search_performed
  nearby_clicked
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  bio          String?
  location     String?
  role         Role     @default(user)
  locale       String   @default("vi")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviews       Review[]
  collections   Collection[]
  favorites     Favorite[]
  questions     Question[]
  answers       Answer[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  auditLogs     AuditLog[]           @relation("AuditActor")
  tripPlans     TripPlan[]
  leads         Lead[]
  analytics     AnalyticsEvent[]
}

// Stored hash of a refresh token. We rotate refresh tokens on each /auth/refresh
// call: the old row is marked revoked and a new one is inserted. This catches
// stolen-token reuse (if an old hash is used after rotation, we revoke the
// entire chain for that user).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, revokedAt])
}

// Single-use password reset token, stored as a hash. Plaintext value is sent to
// the user via email (stub for now — logged to server console).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, usedAt])
}

model Region {
  id       String   @id @default(cuid())
  slug     String   @unique
  nameVi   String
  nameEn   String
  parentId String?
  parent   Region?  @relation("RegionParent", fields: [parentId], references: [id])
  children Region[] @relation("RegionParent")
  places   Place[]
}

model Category {
  id     String          @id @default(cuid())
  slug   String          @unique
  nameVi String
  nameEn String
  icon   String?
  places PlaceCategory[]
}

model Place {
  id              String      @id @default(cuid())
  locationKey     String?     @unique
  slug            String      @unique
  titleVi         String
  titleEn         String?
  summaryVi       String?
  summaryEn       String?
  descriptionVi   String?
  descriptionEn   String?
  regionId        String
  region          Region      @relation(fields: [regionId], references: [id])
  province        String      @default("Gia Lai")
  aliases         String[]    @default([])
  address         String?
  lat             Float?
  lng             Float?
  bestSeasons     String[]    @default([])
  status          PlaceStatus @default(draft)
  heroImageUrl    String?
  heroImageS3Key  String?
  qdrantPlaceSlug String?
  isAiReady       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  photos          Photo[]
  categories      PlaceCategory[]
  reviews         Review[]
  questions       Question[]
  favorites       Favorite[]
  collectionItems CollectionItem[]
  tripPlanItems   TripPlanPlace[]

  @@index([locationKey])
  @@index([regionId, status])
  @@index([province, status])
  @@index([isAiReady])
  @@index([status, updatedAt])
}

model Photo {
  id        String   @id @default(cuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  // Public URL on Cloudinary (or any CDN). Resize/format params should be
  // appended on the client via the helper in apps/web.
  url       String
  s3Key     String?
  // Cloudinary public_id, used for transformations + deletes.
  publicId  String?
  width     Int?
  height    Int?
  alt       String?
  position  Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([placeId, s3Key])
  @@index([placeId, position])
}

model PlaceCategory {
  placeId    String
  categoryId String
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([placeId, categoryId])
}

model Review {
  id        String       @id @default(cuid())
  placeId   String
  userId    String
  rating    Int
  content   String
  status    ReviewStatus @default(visible)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  place Place        @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes ReviewLike[]

  @@index([placeId, createdAt])
}

model ReviewLike {
  reviewId  String
  userId    String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
}

model Question {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean          @default(false)
  coverUrl    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]
}

model CollectionItem {
  collectionId String
  placeId      String
  position     Int        @default(0)
  note         String?
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place        Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([collectionId, placeId])
}

model Favorite {
  userId    String
  placeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
}

// AuditLog — records administrative actions for the admin "Hoạt động Gần đây"
// feed. `actorId` may be null when the actor was deleted (User FK is SET NULL).
// `entityType` + `entityId` describe the target resource (e.g. "place" / cuid,
// "review" / cuid). `action` is a short verb-noun like "place.publish",
// "review.hide", "place.create", etc. `metadata` is free-form JSON for any
// extra context (old slug, status transition, etc.).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model AiUsage {
  id           String         @id @default(cuid())
  keyType      AiUsageKeyType
  keyHash      String
  date         DateTime       @db.Date
  aiRequests   Int            @default(0)
  imageUploads Int            @default(0)
  tripPlanRequests Int         @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([keyType, keyHash, date])
  @@index([date])
  @@index([keyType, keyHash])
}

model TripPlan {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  input     Json
  output    Json
  shareId   String?  @unique
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  places TripPlanPlace[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model TripPlanPlace {
  tripPlanId String
  placeId    String
  position   Int     @default(0)
  tripPlan   TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([tripPlanId, placeId])
  @@index([placeId])
}

model Lead {
  id                  String     @id @default(cuid())
  name                String
  phoneOrZalo         String
  email               String?
  interestedPlaceSlug String?
  interestedPlaceName String?
  area                String?
  travelDate          DateTime?
  peopleCount         Int?
  budget              String?
  note                String?
  source              LeadSource @default(other)
  status              LeadStatus @default(new)
  internalNote        String?
  estimatedValue      String?
  ipHash              String?
  userAgentHash       String?
  userId              String?
  user                User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([interestedPlaceSlug])
  @@index([userId])
}

model DataReport {
  id        String           @id @default(cuid())
  placeSlug String
  type      DataReportType
  message   String
  contact   String?
  status    DataReportStatus @default(new)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([placeSlug])
  @@index([status, createdAt])
}

model AnalyticsEvent {
  id          String             @id @default(cuid())
  type        AnalyticsEventType
  placeSlug   String?
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionHash String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([type, createdAt])
  @@index([placeSlug, createdAt])
  @@index([userId, createdAt])
}
