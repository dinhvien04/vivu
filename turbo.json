{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV", "VERCEL_ENV"],
  "globalPassThroughEnv": ["*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "API_INTERNAL_URL",
        "INCLUDE_DYNAMIC_SITEMAP",
        "CSP_CONNECT_SRC_EXTRA",
        "CSP_IMG_SRC_EXTRA",
        "NEXT_IMAGE_REMOTE_HOSTS",
        "NEXT_PUBLIC_SITE_URL",
        "VERCEL_PROJECT_PRODUCTION_URL"
      ],
      "passThroughEnv": [
        "PORT",
        "DATABASE_URL",
        "CORS_ORIGINS",
        "JWT_ACCESS_SECRET",
        "JWT_REFRESH_SECRET",
        "CLOUDINARY_URL",
        "QDRANT_URL",
        "QDRANT_API_KEY",
        "QDRANT_TEXT_COLLECTION",
        "QDRANT_IMAGE_COLLECTION",
        "QDRANT_TEXT_MODEL",
        "QDRANT_IMAGE_MODEL",
        "QDRANT_IMAGE_TEXT_MODEL",
        "TOP_K_TEXT",
        "TOP_K_IMAGES",
        "IMAGE_MATCH_THRESHOLD",
        "AI_MAX_IMAGE_SIZE_BYTES",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "GEMINI_TIMEOUT_MS",
        "GEMINI_MAX_OUTPUT_TOKENS",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "AWS_BUCKET_NAME",
        "S3_PRESIGNED_EXPIRES_IN",
        "S3_PRESIGNED_CACHE_MAX_ENTRIES",
        "S3_SERVER_SIDE_ENCRYPTION",
        "GLOBAL_RATE_LIMIT_PER_MINUTE",
        "ABUSE_HASH_SECRET",
        "AI_DAILY_QUOTA_ANON",
        "AI_DAILY_QUOTA_USER",
        "AI_CHAT_RATE_LIMIT_PER_MINUTE",
        "TRIP_PLANNER_RATE_LIMIT_PER_MINUTE",
        "TRIP_PLANNER_DAILY_QUOTA_ANON",
        "TRIP_PLANNER_DAILY_QUOTA_USER",
        "LEADS_RATE_LIMIT_PER_HOUR",
        "DATA_REPORT_RATE_LIMIT_PER_HOUR",
        "AUTH_RATE_LIMIT_PER_15_MIN",
        "SEARCH_RATE_LIMIT_PER_MINUTE",
        "TURNSTILE_ENABLED",
        "TURNSTILE_SECRET_KEY",
        "SWAGGER_ENABLED",
        "AUTH_LOGIN_MAX_FAILURES",
        "AUTH_LOGIN_LOCKOUT_WINDOW_MS",
        "QDRANT_TIMEOUT_MS",
        "REFERENCE_DATA_CACHE_TTL_MS",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_CALLBACK_URL",
        "GOOGLE_ALLOWED_REDIRECTS",
        "CONDUIT_ENABLED",
        "CONDUIT_API_KEY",
        "CONDUIT_BASE_URL",
        "CONDUIT_DEFAULT_MODEL",
        "CONDUIT_TRIP_PLANNER_MODEL",
        "CONDUIT_CHAT_MODEL",
        "CONDUIT_TIMEOUT_MS",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "RESEND_API_KEY",
        "PASSWORD_RESET_WEB_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  }
}
