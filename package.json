{
  "name": "vivu",
  "version": "0.0.0",
  "private": true,
  "description": "Vivu - Nen tang kham pha va hoi dap du lich Gia Lai",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "prisma:generate": "pnpm --filter @vivu/api prisma:generate",
    "typecheck": "pnpm prisma:generate && turbo run typecheck",
    "e2e:web": "pnpm --filter @vivu/web test:e2e",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --end-of-line auto",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@fastify/middie": "^9.3.2",
      "@grpc/grpc-js": "^1.14.4",
      "@babel/core": "^7.29.6",
      "fast-uri": "^3.1.2",
      "fastify": "^5.8.5",
      "form-data": "^4.0.6",
      "glob": "^10.5.0",
      "lodash": "^4.18.1",
      "picomatch": "^4.0.4",
      "postcss": "^8.5.10",
      "js-yaml": "^4.2.0",
      "qs": "^6.15.2",
      "tmp": "^0.2.6",
      "protobufjs": "^7.6.3",
      "uuid": "^11.1.1"
    }
  }
}
